<Window x:Class="Loadarr.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        Title="Loadarr — Settings"
        Width="640" Height="540"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        FontSize="13"
        Foreground="#E6E8EE"
        Background="#16181F">

    <Window.Resources>
        <SolidColorBrush x:Key="Surface"       Color="#20232E"/>
        <SolidColorBrush x:Key="Border"        Color="#3A3F4F"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#E6E8EE"/>
        <SolidColorBrush x:Key="TextDim"       Color="#9097A8"/>
        <SolidColorBrush x:Key="Accent"        Color="#F0A958"/>
        <SolidColorBrush x:Key="AccentHover"   Color="#F5BD7A"/>
        <SolidColorBrush x:Key="AccentPressed" Color="#D89043"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#CC1B1E27"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SelectionBrush" Value="{StaticResource Accent}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Background="Transparent"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="box"
                                    Width="18" Height="18"
                                    Background="#CC1B1E27"
                                    BorderBrush="{StaticResource Border}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    VerticalAlignment="Center">
                                <Path x:Name="check"
                                      Stroke="{StaticResource Accent}"
                                      StrokeThickness="2"
                                      Data="M 3 9 L 8 14 L 15 5"
                                      Visibility="Collapsed"
                                      Stretch="None"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#11FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="#1A1300"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentPressed}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   TextDecorations="Underline"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
            <TextBlock Text="L O A D A R R"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource Accent}"/>
            <TextBlock Text="S E T T I N G S"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource TextDim}"
                       VerticalAlignment="Center"
                       Margin="14,5,0,0"/>
        </StackPanel>

        <!-- Form -->
        <StackPanel Grid.Row="1">
            <!-- Download directory -->
            <TextBlock Text="Download directory" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="Where ROMs land before LaunchBox import."
                       FontSize="11" Foreground="{StaticResource TextDim}"
                       Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="DownloadDirBox" Grid.Column="0" Margin="0,0,8,0"/>
                <Button Grid.Column="1"
                        Content="Browse…"
                        Style="{StaticResource GhostButton}"
                        Click="OnBrowseDownloadDir"/>
            </Grid>

            <!-- Extract archives -->
            <CheckBox x:Name="ExtractCheck"
                      Content="Extract downloaded archives"
                      Margin="0,0,0,4"/>
            <TextBlock Text="Pulls the primary ROM out of .zip / .7z / .rar. Disc images (.cue + .bin, .gdi + .raw) and arcade romsets are handled automatically."
                       FontSize="11" Foreground="{StaticResource TextDim}"
                       TextWrapping="Wrap"
                       Margin="28,0,0,16"/>

            <!-- Debug logging -->
            <CheckBox x:Name="DebugCheck"
                      Content="Enable debug logging"
                      Margin="0,0,0,4"/>
            <Grid Margin="28,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Writes per-import diagnostics to %APPDATA%\Loadarr\loadarr.log."
                           FontSize="11" Foreground="{StaticResource TextDim}"
                           TextWrapping="Wrap"/>
                <Button Grid.Column="1"
                        Content="Open log folder"
                        Style="{StaticResource LinkButton}"
                        Margin="12,0,0,0"
                        FontSize="11"
                        VerticalAlignment="Top"
                        Click="OnOpenLogFolder"/>
            </Grid>

            <!-- Search timeout -->
            <TextBlock Text="Search timeout (seconds)" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="HTTP timeout for searches and downloads."
                       FontSize="11" Foreground="{StaticResource TextDim}"
                       Margin="0,0,0,6"/>
            <TextBox x:Name="TimeoutBox" Width="100" HorizontalAlignment="Left"
                     PreviewTextInput="OnTimeoutPreviewTextInput"/>
        </StackPanel>

        <!-- Footer -->
        <DockPanel Grid.Row="2" LastChildFill="False" Margin="0,12,0,0">
            <Button DockPanel.Dock="Right"
                    Content="Save"
                    Style="{StaticResource AccentButton}"
                    Click="OnSave"
                    IsDefault="True"/>
            <Button DockPanel.Dock="Right"
                    Content="Cancel"
                    Style="{StaticResource GhostButton}"
                    Click="OnCancel"
                    IsCancel="True"
                    Margin="0,0,8,0"/>
        </DockPanel>
    </Grid>
</Window>
